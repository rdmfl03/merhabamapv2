# Generic local development example
# Copy this to .env.local for development.
# Use .env.production.example as the production/Netlify reference.

# Database
DATABASE_URL="postgresql://localhost:5432/merhabamap_dev"
DIRECT_URL="postgresql://localhost:5432/merhabamap_dev"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_ENABLE_PASSWORD_LOGIN="true"
AUTH_ALLOW_CREDENTIALS_MOCK="false"
AUTH_DEMO_CREDENTIALS_ENABLED="true"
# Optional local-only password for seeded demo accounts.
DEMO_ACCOUNT_PASSWORD=""

# App / runtime
APP_NAME="MerhabaMap"
APP_URL="http://localhost:3000"
DEFAULT_LOCALE="de"
APP_ENV="development"
LOG_LEVEL="info"
READINESS_ENABLE_DB_CHECK="true"
NEXT_PUBLIC_ENABLE_DEV_DEMO_UI="true"

# Email
EMAIL_TRANSPORT="log"
RESEND_API_KEY=""
EMAIL_VERIFICATION_TOKEN_TTL_HOURS="24"
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"

# Storage (optional)
S3_REGION="eu-central-1"
S3_BUCKET="merhabamap-assets"
S3_ENDPOINT="https://example.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Maps: MapTiler Pastel raster tiles via /api/map-tiles (server-only). Without a key, maps use OSM.
# Get a key at https://cloud.maptiler.com/ — never use NEXT_PUBLIC_* for this.
# MAPTILER_API_KEY="your_key_here"
# Optional aliases if your host uses another name: MAPTILER_KEY or MAP_TILER_API_KEY
# URL-restricted MapTiler keys: set APP_URL (or Netlify URL / AUTH_URL) so /api/map-tiles can send Referer.
