# Generic local development example
# Copy this to .env.local for development.
# Use .env.production.example as the production/Netlify reference.

# Database
DATABASE_URL="postgresql://localhost:5432/merhabamap_dev"
DIRECT_URL="postgresql://localhost:5432/merhabamap_dev"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_ENABLE_PASSWORD_LOGIN="true"
AUTH_ALLOW_CREDENTIALS_MOCK="false"
AUTH_DEMO_CREDENTIALS_ENABLED="true"

# App / runtime
APP_NAME="MerhabaMap"
APP_URL="http://localhost:3000"
DEFAULT_LOCALE="de"
APP_ENV="development"
LOG_LEVEL="info"
READINESS_ENABLE_DB_CHECK="true"
NEXT_PUBLIC_ENABLE_DEV_DEMO_UI="true"

# Email
EMAIL_TRANSPORT="log"
RESEND_API_KEY=""
EMAIL_VERIFICATION_TOKEN_TTL_HOURS="24"
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"

# Storage (optional)
S3_REGION="eu-central-1"
S3_BUCKET="merhabamap-assets"
S3_ENDPOINT="https://example.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Maps
NEXT_PUBLIC_MAP_PROVIDER="osm"
NEXT_PUBLIC_MAPBOX_TOKEN=""
