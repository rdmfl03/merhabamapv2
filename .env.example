# Generic local development example
# ---------------------------------------------------------------------------
# Local dev: copy this file to `.env.local` and put your real values there only.
# `.env.local` is gitignored — never commit passwords or production URLs into the repo.
# Production / Netlify: use `.env.production.example` as a checklist; set vars in the host UI.
# `npm run dev` and Prisma load env via `scripts/run-with-env.mjs` (`.env.example` then `.env.local`).
# ---------------------------------------------------------------------------

# Database (Prisma uses DATABASE_URL in prisma/schema.prisma)
# Local: Docker Postgres, a dev DigitalOcean DB, pool URL, etc. — only in `.env.local` for real credentials.
# Optional DIRECT_URL: same as DATABASE_URL unless you later split pool vs direct for migrations.
DATABASE_URL="postgresql://localhost:5432/merhabamap_dev"
DIRECT_URL="postgresql://localhost:5432/merhabamap_dev"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_ENABLE_PASSWORD_LOGIN="true"
AUTH_ALLOW_CREDENTIALS_MOCK="false"
AUTH_DEMO_CREDENTIALS_ENABLED="false"
# Optional invite-only signup gate for production/public rollouts.
# Keep real codes only in host env UI or `.env.local`, never commit them.
AUTH_SIGNUP_INVITE_CODES=""
# Optional local-only password for seeded demo accounts.
DEMO_ACCOUNT_PASSWORD=""

# App / runtime
APP_NAME="MerhabaMap"
APP_URL="http://localhost:3000"
DEFAULT_LOCALE="de"
APP_ENV="development"
LOG_LEVEL="info"
READINESS_ENABLE_DB_CHECK="true"
NEXT_PUBLIC_ENABLE_DEV_DEMO_UI="false"

# Email
EMAIL_TRANSPORT="log"
RESEND_API_KEY=""
EMAIL_VERIFICATION_TOKEN_TTL_HOURS="24"
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"

# Storage (optional)
S3_REGION="eu-central-1"
S3_BUCKET="merhabamap-assets"
S3_ENDPOINT="https://example.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Maps: Stadia raster tiles via /api/map-tiles (server-only). Without a key, maps use OSM.
# Get a key at https://stadiamaps.com/ — never use NEXT_PUBLIC_* for this.
# STADIA_API_KEY="your_key_here"
