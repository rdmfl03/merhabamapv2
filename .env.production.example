# Canonical production / Netlify example
# Add the real values manually in the Netlify UI. Do not commit secrets.

# Runtime
NODE_ENV="production"
APP_ENV="production"
APP_NAME="MerhabaMap"
APP_URL="https://www.merhabamap.com"
DEFAULT_LOCALE="de"
LOG_LEVEL="info"
READINESS_ENABLE_DB_CHECK="true"

# Database (Netlify / production only)
# Use DigitalOcean "Connection pool" credentials — NOT the primary cluster "doadmin" URL.
# Local development: keep using the direct DB user (e.g. doadmin) in .env.local (gitignored).
#
# Pool (typical DO values): port 25061, pool DB name (e.g. mm_pool), app user (e.g. mm_app).
# Append for serverless + Prisma (adjust after testing): &pgbouncer=true&connection_limit=5
# If queries fail with pooler, try without pgbouncer=true (session pool) per DO docs.
DATABASE_URL="postgresql://POOL_USER:POOL_PASSWORD@YOUR-POOL-HOST.db.ondigitalocean.com:25061/mm_pool?sslmode=require&pgbouncer=true&connection_limit=5"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="https://www.merhabamap.com"
AUTH_ENABLE_PASSWORD_LOGIN="true"
# Self-service signup: keep false (or omit) on public production; code defaults signup off when unset.
AUTH_ALLOW_SIGNUP="false"
AUTH_DEMO_CREDENTIALS_ENABLED="false"
AUTH_ALLOW_CREDENTIALS_MOCK="false"

# Demo / client flags
NEXT_PUBLIC_ENABLE_DEV_DEMO_UI="false"

# Email
EMAIL_TRANSPORT="resend"
RESEND_API_KEY=""
EMAIL_VERIFICATION_TOKEN_TTL_HOURS="24"
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"

# Storage — profile avatars on DigitalOcean Spaces (recommended on Netlify; local disk is not persistent).
# Set all five or omit all five (partial config fails env validation).
# Endpoint: https://REGION.digitaloceanspaces.com  |  Public URL: https://BUCKET.REGION.cdn.digitaloceanspaces.com (with CDN)
S3_REGION="fra1"
S3_BUCKET="merhabamap-bucket"
S3_ENDPOINT="https://fra1.digitaloceanspaces.com"
S3_PUBLIC_BASE_URL="https://merhabamap-bucket.fra1.cdn.digitaloceanspaces.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Maps (optional): MAPTILER_API_KEY as Netlify secret only — see docs/netlify-deploy.md.

# Google Places (optional, server-only): reserved for a future server-side photo proxy / Places API.
# Never expose in NEXT_PUBLIC_* . Ratings in the app come from the database (ingest), not live client calls.
# GOOGLE_PLACES_API_KEY=""

# Netlify / Node
# These are deployment/runtime settings rather than app-level secrets.
NODE_VERSION="20"
NETLIFY_NEXT_SKEW_PROTECTION="true"
