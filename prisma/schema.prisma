generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserActionToken {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  type       UserActionTokenType
  tokenHash  String              @unique @map("token_hash")
  expiresAt  DateTime            @map("expires_at")
  consumedAt DateTime?           @map("consumed_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("user_action_tokens")
}

model User {
  id                    String             @id @default(cuid())
  email                 String?            @unique
  hashedPassword        String?            @map("hashed_password")
  emailVerified         DateTime?          @map("email_verified")
  name                  String?
  username              String?            @unique
  image                 String?
  role                  Role               @default(USER)
  preferredLocale       Locale?            @map("preferred_locale")
  onboardingCompletedAt DateTime?          @map("onboarding_completed_at")
  interestsJson         String?            @map("interests_json")
  onboardingCityId      String?            @map("onboarding_city_id")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  accounts              Account[]
  adminActionLogs       AdminActionLog[]
  aiRecheckRequests     AiRecheckRequest[]
  reviewedClaims        BusinessClaim[]    @relation("ClaimReviewer")
  businessClaims        BusinessClaim[]
  ownedPlaces           Place[]            @relation("PlaceOwner")
  verifiedPlaces        Place[]            @relation("PlaceVerifier")
  reviewedReports       Report[]           @relation("ReportReviewer")
  reports               Report[]
  savedEvents           SavedEvent[]
  savedPlaces           SavedPlace[]
  sessions              Session[]
  reviewedSubmissions   Submission[]       @relation("ReviewedSubmissions")
  submittedSubmissions  Submission[]       @relation("SubmittedSubmissions")
  actionTokens          UserActionToken[]
  onboardingCity        City?              @relation("OnboardingCity", fields: [onboardingCityId], references: [id])
  activities            Activity[]
  followsInitiated      Follow[]           @relation("FollowFollower")
  followsReceived       Follow[]           @relation("FollowFollowing")
  entityComments        EntityComment[]
  eventParticipations   EventParticipation[]
  placeCollections      PlaceCollection[]
  cityFollows           CityFollow[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsAsActor  Notification[] @relation("NotificationActor")
  entityContributions   EntityContribution[]

  @@index([role])
  @@map("users")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType @map("notification_type")
  actorUserId String?          @map("actor_user_id")
  entityType  String?          @map("entity_type")
  entityId    String?          @map("entity_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  readAt      DateTime?        @map("read_at")
  recipient   User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

model EntityContribution {
  id         String                       @id @default(cuid())
  userId     String                       @map("user_id")
  entityType EntityContributionEntityType @map("entity_type")
  entityId   String                       @map("entity_id")
  role       EntityContributionRole       @map("role")
  createdAt  DateTime                     @default(now()) @map("created_at")
  user       User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId, role])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("entity_contributions")
}

model Activity {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  type       String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("activities")
}

model Follow {
  id              String   @id @default(cuid())
  followerId      String   @map("follower_id")
  followingUserId String   @map("following_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  follower        User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following       User     @relation("FollowFollowing", fields: [followingUserId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingUserId])
  @@index([followerId])
  @@index([followingUserId])
  @@map("follows")
}

model EntityComment {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  content    String    @db.VarChar(500)
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    Report[]

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("entity_comments")
}

model EventParticipation {
  id        String                   @id @default(cuid())
  userId    String                   @map("user_id")
  eventId   String                   @map("event_id")
  status    EventParticipationStatus
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@map("event_participations")
}

model PlaceCollection {
  id          String                   @id @default(cuid())
  userId      String                   @map("user_id")
  title       String                   @db.VarChar(80)
  description String?                  @db.VarChar(300)
  visibility  PlaceCollectionVisibility
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PlaceCollectionItem[]
  reports     Report[]

  @@index([userId])
  @@index([visibility])
  @@map("place_collections")
}

model PlaceCollectionItem {
  id           String          @id @default(cuid())
  collectionId String          @map("collection_id")
  placeId      String          @map("place_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  collection   PlaceCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place        Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, placeId])
  @@index([collectionId])
  @@index([placeId])
  @@map("place_collection_items")
}

model CityFollow {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  cityId    String   @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([userId])
  @@index([cityId])
  @@map("city_follows")
}

model City {
  id              String    @id @default(cuid())
  slug            String    @unique
  nameDe          String    @map("name_de")
  nameTr          String    @map("name_tr")
  countryCode     String    @default("DE") @map("country_code")
  isPilot         Boolean   @default(false) @map("is_pilot")
  stateCode       String?   @map("state_code")
  ags             String?
  lat             Float?
  lng             Float?
  source          String?
  sourceUpdatedAt DateTime? @map("source_updated_at") @db.Timestamp(6)
  events                 Event[]
  normalizedIngestEvents NormalizedIngestEvent[]
  places                 Place[]
  usersOnboarding        User[] @relation("OnboardingCity")
  cityFollows            CityFollow[]

  @@index([stateCode])
  @@index([countryCode])
  @@index([lat, lng])
  @@map("cities")
}

model PlaceCategory {
  id        String  @id @default(cuid())
  slug      String  @unique
  nameDe    String  @map("name_de")
  nameTr    String  @map("name_tr")
  icon      String?
  sortOrder Int     @default(0) @map("sort_order")
  places    Place[]

  @@map("place_categories")
}

model Place {
  id                   String             @id @default(cuid())
  slug                 String             @unique
  name                 String
  descriptionDe        String?            @map("description_de")
  descriptionTr        String?            @map("description_tr")
  categoryId           String             @map("category_id")
  cityId               String             @map("city_id")
  ownerUserId          String?            @map("owner_user_id")
  addressLine1         String?            @map("address_line_1")
  postalCode           String?            @map("postal_code")
  latitude             Float?
  longitude            Float?
  phone                String?
  websiteUrl           String?            @map("website_url")
  openingHoursJson     String?            @map("opening_hours_json")
  images               String[]           @default([])
  primaryImageAssetId  String?            @map("primary_image_asset_id")
  fallbackImageAssetId String?            @map("fallback_image_asset_id")
  imageSetStatus       ImageSetStatus     @default(MISSING) @map("image_set_status")
  displayRatingValue   Decimal?           @map("display_rating_value") @db.Decimal(3, 2)
  displayRatingCount   Int?               @map("display_rating_count")
  ratingSourceCount    Int                @default(0) @map("rating_source_count")
  ratingSummaryUpdatedAt DateTime?        @map("rating_summary_updated_at") @db.Timestamp(6)
  isPublished          Boolean            @default(false) @map("is_published")
  verificationStatus   VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verifiedAt           DateTime?          @map("verified_at")
  verifiedByUserId     String?            @map("verified_by_user_id")
  lastBusinessUpdateAt DateTime?          @map("last_business_update_at")
  moderationStatus     ModerationStatus   @default(PENDING) @map("moderation_status")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  aiReviewStatus       String?            @map("ai_review_status")
  aiConfidenceScore    Decimal?           @map("ai_confidence_score") @db.Decimal(5, 4)
  aiLastCheckedAt      DateTime?          @map("ai_last_checked_at") @db.Timestamp(6)
  claims               BusinessClaim[]
  mediaAssets          MediaAsset[]       @relation("PlaceMediaAssets")
  primaryImageAsset    MediaAsset?        @relation("PlacePrimaryImageAsset", fields: [primaryImageAssetId], references: [id], onDelete: SetNull)
  fallbackImageAsset   MediaAsset?        @relation("PlaceFallbackImageAsset", fields: [fallbackImageAssetId], references: [id], onDelete: SetNull)
  placeSources         PlaceSource[]
  placeRatingSources   PlaceRatingSource[]
  category             PlaceCategory      @relation(fields: [categoryId], references: [id])
  city                 City               @relation(fields: [cityId], references: [id], onDelete: Cascade)
  owner                User?              @relation("PlaceOwner", fields: [ownerUserId], references: [id])
  verifiedBy           User?              @relation("PlaceVerifier", fields: [verifiedByUserId], references: [id])
  reports              Report[]
  savedBy              SavedPlace[]
  venueEvents          Event[]            @relation("EventVenuePlace")
  collectionItems      PlaceCollectionItem[]

  @@index([cityId])
  @@index([categoryId])
  @@index([ownerUserId])
  @@index([moderationStatus])
  @@index([isPublished])
  @@index([imageSetStatus])
  @@index([primaryImageAssetId])
  @@index([fallbackImageAssetId])
  @@index([name(ops: raw("gin_trgm_ops"))], map: "places_name_trgm_idx", type: Gin)
  @@map("places")
}

model Event {
  id                String           @id @default(cuid())
  slug              String           @unique
  title             String
  descriptionDe     String?          @map("description_de")
  descriptionTr     String?          @map("description_tr")
  category          EventCategory
  cityId            String           @map("city_id")
  venueName         String?          @map("venue_name")
  addressLine1      String?          @map("address_line_1")
  postalCode        String?          @map("postal_code")
  latitude          Float?
  longitude         Float?
  startsAt          DateTime         @map("starts_at")
  endsAt            DateTime?        @map("ends_at")
  organizerName     String?          @map("organizer_name")
  externalUrl       String?          @map("external_url")
  imageUrl          String?          @map("image_url")
  primaryImageAssetId  String?       @map("primary_image_asset_id")
  fallbackImageAssetId String?       @map("fallback_image_asset_id")
  imageSetStatus       ImageSetStatus @default(MISSING) @map("image_set_status")
  venuePlaceId         String?       @map("venue_place_id")
  isPublished       Boolean          @default(false) @map("is_published")
  moderationStatus  ModerationStatus @default(PENDING) @map("moderation_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  aiReviewStatus    String?          @map("ai_review_status")
  aiConfidenceScore Decimal?         @map("ai_confidence_score") @db.Decimal(5, 4)
  aiLastCheckedAt   DateTime?        @map("ai_last_checked_at") @db.Timestamp(6)
  mediaAssets           MediaAsset[]       @relation("EventMediaAssets")
  primaryImageAsset     MediaAsset?        @relation("EventPrimaryImageAsset", fields: [primaryImageAssetId], references: [id], onDelete: SetNull)
  fallbackImageAsset    MediaAsset?        @relation("EventFallbackImageAsset", fields: [fallbackImageAssetId], references: [id], onDelete: SetNull)
  eventSources           EventSource[]
  normalizedIngestEvents NormalizedIngestEvent[]
  city                   City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  venuePlace             Place?           @relation("EventVenuePlace", fields: [venuePlaceId], references: [id], onDelete: SetNull)
  reports                Report[]
  savedBy                SavedEvent[]
  participations         EventParticipation[]

  @@unique([title, cityId, startsAt], map: "events_unique_event")
  @@unique([title, cityId, startsAt], map: "events_unique_title_city_starts_at")
  @@index([cityId])
  @@index([category])
  @@index([startsAt])
  @@index([isPublished])
  @@index([moderationStatus])
  @@index([imageSetStatus])
  @@index([primaryImageAssetId])
  @@index([fallbackImageAssetId])
  @@index([venuePlaceId])
  @@index([title(ops: raw("gin_trgm_ops"))], map: "events_title_trgm_idx", type: Gin)
  @@map("events")
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([userId])
  @@index([placeId, createdAt(sort: Desc)])
  @@map("saved_places")
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId, createdAt(sort: Desc)])
  @@map("saved_events")
}

model BusinessClaim {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  placeId          String      @map("place_id")
  claimantName     String      @map("claimant_name")
  claimantEmail    String      @map("claimant_email")
  claimantPhone    String?     @map("claimant_phone")
  message          String?
  evidenceNotes    String?     @map("evidence_notes")
  status           ClaimStatus @default(PENDING)
  adminNotes       String?     @map("admin_notes")
  reviewedAt       DateTime?   @map("reviewed_at")
  reviewedByUserId String?     @map("reviewed_by_user_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  place            Place       @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reviewedBy       User?       @relation("ClaimReviewer", fields: [reviewedByUserId], references: [id])
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([status])
  @@map("business_claims")
}

model Report {
  id                  String           @id @default(cuid())
  userId              String?          @map("user_id")
  targetType          ReportTargetType @map("target_type")
  placeId             String?          @map("place_id")
  eventId             String?          @map("event_id")
  entityCommentId     String?          @map("entity_comment_id")
  placeCollectionId   String?          @map("place_collection_id")
  reason              String
  details             String?
  status              ReportStatus     @default(OPEN)
  reviewedAt          DateTime?        @map("reviewed_at")
  reviewedByUserId    String?          @map("reviewed_by_user_id")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  entityComment       EntityComment?   @relation(fields: [entityCommentId], references: [id], onDelete: SetNull)
  event               Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  place               Place?           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  placeCollection     PlaceCollection? @relation(fields: [placeCollectionId], references: [id], onDelete: SetNull)
  reviewedBy          User?            @relation("ReportReviewer", fields: [reviewedByUserId], references: [id])
  user                User?            @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([targetType])
  @@index([placeId])
  @@index([eventId])
  @@index([entityCommentId])
  @@index([placeCollectionId])
  @@map("reports")
}

model AdminActionLog {
  id           String   @id @default(cuid())
  actorUserId  String   @map("actor_user_id")
  actionType   String   @map("action_type")
  targetType   String   @map("target_type")
  targetId     String   @map("target_id")
  summary      String
  metadataJson String?  @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  admin        User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("admin_action_logs")
}

/// First-party, low-cardinality product usage events (no PII, no raw search text).
model ProductInsightEvent {
  id        String   @id @default(cuid())
  name      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@map("product_insight_events")
}

model AiRecheckRequest {
  id                String                 @id @default(cuid())
  entityType        AiRecheckEntityType    @map("entity_type")
  entityId          String                 @map("entity_id")
  requestedByUserId String                 @map("requested_by_user_id")
  status            AiRecheckRequestStatus @default(PENDING)
  processedAt       DateTime?              @map("processed_at")
  errorMessage      String?                @map("error_message")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  requestedByUser   User                   @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
  @@map("ai_recheck_requests")
}

model Source {
  id              String          @id
  platform        String
  sourceKind      String          @map("source_kind")
  name            String?
  url             String          @unique
  accountHandle   String?         @map("account_handle")
  externalId      String?         @map("external_id")
  isPublic        Boolean         @default(true) @map("is_public")
  isActive        Boolean         @default(true) @map("is_active")
  trustScore      Int             @default(50) @map("trust_score")
  discoveryMethod String?         @map("discovery_method")
  notes           String?
  lastCheckedAt   DateTime?       @map("last_checked_at") @db.Timestamp(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime        @default(now()) @map("updated_at") @db.Timestamp(6)
  eventSources    EventSource[]
  ingestRuns      IngestRun[]
  mediaAssets     MediaAsset[]
  placeRatingSources PlaceRatingSource[]
  placeSources    PlaceSource[]
  rawIngestItems  RawIngestItem[]

  @@index([isActive])
  @@index([platform])
  @@index([sourceKind])
  @@index([trustScore])
  @@map("sources")
}

model MediaAsset {
  id              String              @id @default(cuid())
  placeId          String?             @map("place_id")
  eventId          String?             @map("event_id")
  sourceId         String?             @map("source_id")
  assetUrl         String              @map("asset_url")
  sourceProvider   MediaSourceProvider @map("source_provider")
  sourceUrl        String?             @map("source_url")
  externalRef      String?             @map("external_ref")
  role             MediaAssetRole
  status           MediaAssetStatus    @default(PENDING_REVIEW)
  rightsStatus     MediaRightsStatus   @default(UNKNOWN) @map("rights_status")
  attributionText  String?             @map("attribution_text")
  attributionUrl   String?             @map("attribution_url")
  altText          String?             @map("alt_text")
  sortOrder        Int                 @default(0) @map("sort_order")
  observedAt       DateTime?           @map("observed_at") @db.Timestamp(6)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)
  place            Place?              @relation("PlaceMediaAssets", fields: [placeId], references: [id], onDelete: Cascade)
  event            Event?              @relation("EventMediaAssets", fields: [eventId], references: [id], onDelete: Cascade)
  source           Source?             @relation(fields: [sourceId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  primaryForPlaces Place[]             @relation("PlacePrimaryImageAsset")
  fallbackForPlaces Place[]            @relation("PlaceFallbackImageAsset")
  primaryForEvents Event[]             @relation("EventPrimaryImageAsset")
  fallbackForEvents Event[]            @relation("EventFallbackImageAsset")

  @@index([placeId, status, role, sortOrder])
  @@index([eventId, status, role, sortOrder])
  @@index([sourceId])
  @@index([sourceProvider])
  @@index([status])
  @@index([rightsStatus])
  @@map("media_assets")
}

model EventSource {
  id                   String   @id
  eventId              String   @map("event_id")
  sourceId             String   @map("source_id")
  sourceUrl            String   @map("source_url")
  externalRef          String?  @map("external_ref")
  observedTitle        String?  @map("observed_title")
  observedDatetimeText String?  @map("observed_datetime_text")
  observedLocationText String?  @map("observed_location_text")
  firstSeenAt          DateTime @default(now()) @map("first_seen_at") @db.Timestamp(6)
  lastSeenAt           DateTime @default(now()) @map("last_seen_at") @db.Timestamp(6)
  isPrimary            Boolean  @default(false) @map("is_primary")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  event                Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  source               Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([eventId, sourceId, sourceUrl])
  @@index([eventId])
  @@index([isPrimary])
  @@index([lastSeenAt])
  @@index([sourceId])
  @@map("event_sources")
}

model IngestRun {
  id           String    @id
  pipelineName String    @map("pipeline_name")
  triggerType  String    @map("trigger_type")
  sourceId     String?   @map("source_id")
  status       String    @default("RUNNING")
  itemsFound   Int       @default(0) @map("items_found")
  itemsCreated Int       @default(0) @map("items_created")
  itemsUpdated Int       @default(0) @map("items_updated")
  itemsFailed  Int       @default(0) @map("items_failed")
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamp(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamp(6)
  logText      String?   @map("log_text")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  source       Source?   @relation(fields: [sourceId], references: [id], onUpdate: NoAction)

  @@index([finishedAt])
  @@index([pipelineName])
  @@index([sourceId])
  @@index([startedAt])
  @@index([status])
  @@index([triggerType])
  @@map("ingest_runs")
}

model Organizer {
  id              String   @id
  slug            String   @unique
  name            String
  descriptionDe   String?  @map("description_de")
  descriptionTr   String?  @map("description_tr")
  websiteUrl      String?  @map("website_url")
  email           String?
  phone           String?
  instagramHandle String?  @map("instagram_handle")
  tiktokHandle    String?  @map("tiktok_handle")
  facebookUrl     String?  @map("facebook_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([isVerified])
  @@index([name])
  @@map("organizers")
}

model PlaceSource {
  id              String   @id
  placeId         String   @map("place_id")
  sourceId        String   @map("source_id")
  sourceUrl       String   @map("source_url")
  externalRef     String?  @map("external_ref")
  observedName    String?  @map("observed_name")
  observedAddress String?  @map("observed_address")
  observedPhone   String?  @map("observed_phone")
  observedWebsite String?  @map("observed_website")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at") @db.Timestamp(6)
  lastSeenAt      DateTime @default(now()) @map("last_seen_at") @db.Timestamp(6)
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  place           Place    @relation(fields: [placeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  source          Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([placeId, sourceId, sourceUrl])
  @@index([isPrimary])
  @@index([lastSeenAt])
  @@index([placeId])
  @@index([sourceId])
  @@map("place_sources")
}

model PlaceRatingSource {
  id                   String                 @id @default(cuid())
  placeId              String                 @map("place_id")
  sourceId             String?                @map("source_id")
  provider             RatingSourceProvider
  sourceUrl            String?                @map("source_url")
  externalRef          String?                @map("external_ref")
  status               PlaceRatingSourceStatus @default(PENDING_REVIEW)
  ratingValue          Decimal                @map("rating_value") @db.Decimal(3, 2)
  ratingCount          Int                    @map("rating_count")
  scaleMax             Decimal                @map("scale_max") @db.Decimal(4, 2)
  isIncludedInDisplay  Boolean                @default(true) @map("is_included_in_display")
  observedAt           DateTime?              @map("observed_at") @db.Timestamp(6)
  attributionText      String?                @map("attribution_text")
  attributionUrl       String?                @map("attribution_url")
  reviewTextRightsStatus ReviewTextRightsStatus @default(UNKNOWN) @map("review_text_rights_status")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamp(6)
  place                Place                  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  source               Source?                @relation(fields: [sourceId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([placeId, status, isIncludedInDisplay])
  @@index([sourceId])
  @@index([provider])
  @@index([observedAt])
  @@map("place_rating_sources")
}

model RawIngestItem {
  id              String    @id
  sourceId        String?   @map("source_id")
  entityGuess     String    @map("entity_guess")
  platform        String
  sourceUrl       String?   @map("source_url")
  externalId      String?   @map("external_id")
  rawTitle        String?   @map("raw_title")
  rawText         String?   @map("raw_text")
  rawDatetimeText String?   @map("raw_datetime_text")
  rawLocationText String?   @map("raw_location_text")
  rawImageUrl     String?   @map("raw_image_url")
  rawPayloadJson  String    @map("raw_payload_json")
  languageHint    String?   @map("language_hint")
  cityGuess       String?   @map("city_guess")
  countryCode     String?   @map("country_code")
  status          String    @default("PENDING")
  errorMessage    String?   @map("error_message")
  processedAt     DateTime? @map("processed_at") @db.Timestamp(6)
  ingestedAt      DateTime  @default(now()) @map("ingested_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  normalizedEvent NormalizedIngestEvent?
  source          Source?                @relation(fields: [sourceId], references: [id], onUpdate: NoAction)

  @@index([entityGuess])
  @@index([externalId])
  @@index([ingestedAt])
  @@index([platform])
  @@index([processedAt])
  @@index([sourceId])
  @@index([status])
  @@map("raw_ingest_items")
}

model NormalizedIngestEvent {
  id                  String                      @id
  rawIngestItemId     String                      @unique @map("raw_ingest_item_id")
  eventId             String?                     @unique @map("event_id")
  cityId              String                      @map("city_id")
  title               String
  description         String?
  category            EventCategory
  venueName           String?                     @map("venue_name")
  startsAt            DateTime                    @map("starts_at") @db.Timestamp(6)
  sourceUrl           String                      @map("source_url")
  sourceCategory      String?                     @map("source_category")
  normalizationStatus NormalizedIngestEventStatus @default(PENDING_REVIEW) @map("normalization_status")
  reviewedByUserId    String?                     @map("reviewed_by_user_id")
  reviewedAt          DateTime?                   @map("reviewed_at") @db.Timestamp(6)
  reviewNote          String?                     @map("review_note")
  promotedAt          DateTime?                   @map("promoted_at") @db.Timestamp(6)
  createdAt           DateTime                    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime                    @default(now()) @map("updated_at") @db.Timestamp(6)
  city                City                        @relation(fields: [cityId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  event               Event?                      @relation(fields: [eventId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  rawIngestItem       RawIngestItem               @relation(fields: [rawIngestItemId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cityId])
  @@index([normalizationStatus])
  @@index([reviewedByUserId])
  @@index([startsAt])
  @@map("normalized_ingest_events")
}

model Submission {
  id                String    @id
  submissionType    String    @map("submission_type")
  targetEntityType  String?   @map("target_entity_type")
  targetEntityId    String?   @map("target_entity_id")
  normalizedIngestEventId String? @map("normalized_ingest_event_id")
  submittedByUserId String?   @map("submitted_by_user_id")
  payloadJson       String    @map("payload_json")
  sourceUrl         String?   @map("source_url")
  notes             String?
  status            String    @default("PENDING")
  reviewedByUserId  String?   @map("reviewed_by_user_id")
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamp(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  reviewedByUser    User?     @relation("ReviewedSubmissions", fields: [reviewedByUserId], references: [id], onUpdate: NoAction)
  submittedByUser   User?     @relation("SubmittedSubmissions", fields: [submittedByUserId], references: [id], onUpdate: NoAction)

  @@index([createdAt])
  @@index([reviewedByUserId])
  @@index([status])
  @@index([submissionType])
  @@index([submittedByUserId])
  @@index([targetEntityId])
  @@index([targetEntityType])
  @@index([normalizedIngestEventId])
  @@map("submissions")
}

model AiQualityCheck {
  id              String   @id
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  modelName       String   @map("model_name")
  aiStatus        String   @map("ai_status")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(5, 4)
  reasonCodes     Json?    @map("reason_codes")
  explanation     String?
  suggestedAction String?  @map("suggested_action")
  rawResultJson   Json?    @map("raw_result_json")
  checkedAt       DateTime @default(now()) @map("checked_at") @db.Timestamp(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([entityType, entityId, checkedAt(sort: Desc)], map: "ai_quality_checks_entity_idx")
  @@map("ai_quality_checks")
}

