{
  "name": "merhabamap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "node scripts/run-with-env.mjs next dev",
    "build": "node scripts/run-with-env.mjs next build",
    "start": "node scripts/run-with-env.mjs next start",
    "lint": "eslint .",
    "typecheck": "node scripts/run-with-env.mjs next typegen && tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "test:smoke": "playwright test --grep @smoke",
    "prisma:validate": "node scripts/run-with-env.mjs prisma validate",
    "ci:check": "npm run prisma:validate && npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "db:generate": "node scripts/run-with-env.mjs prisma generate",
    "db:push": "node scripts/run-with-env.mjs prisma db push",
    "db:migrate": "node scripts/run-with-env.mjs prisma migrate dev",
    "db:migrate:deploy": "node scripts/run-with-env.mjs prisma migrate deploy",
    "db:reset": "node scripts/run-with-env.mjs prisma db push --force-reset --skip-generate",
    "db:seed": "node scripts/run-with-env.mjs tsx prisma/seed.ts",
    "db:pilot:replace": "node scripts/run-with-env.mjs tsx scripts/replace-public-pilot-batch.ts",
    "db:reseed": "npm run db:reset && npm run db:generate && npm run db:seed",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "db:studio": "node scripts/run-with-env.mjs prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.511.0",
    "mapbox-gl": "^3.20.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^3.26.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
